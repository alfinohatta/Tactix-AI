# ==============================================================================
# TACTIX AI - GLOBAL CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env and configure for your local/production environment.
# Note: The actual .env file should be kept out of version control.

# --- 🌐 CLOUD BRIDGE (MySQL API Gateway) ---
TACTIX_API_BASE_URL=https://api.example.com/v1/
TACTIX_API_KEY=your_secure_api_key_here
TACTIX_API_TIMEOUT_SEC=30

# --- 🗄️ PERSISTENCE & SYNC ---
# Local SQLite/Room DB name
LOCAL_DB_NAME=tactix_ai_database
# Sync heartbeat for strategy telemetry (Minutes)
SYNC_HEARTBEAT_INTERVAL=15
REMOTE_LOGGING_ENABLED=true

# --- 🧠 SIMOS KERNEL TUNING ---
# Max agents supported by the primitive DOD buffer
MAX_AGENT_CAPACITY=15000
# Target Physics Frequency (ms) - 16ms = 60fps
SIM_TICK_RATE_MS=16
# Parallel Processing Chunk Size (Agents per Coroutine)
COMPUTE_CHUNK_SIZE=2000

# --- 🧪 RESEARCH & ANALYTICS ---
# Enables Monte-Carlo batch logging in the AI Lab
LAB_MODE_DEBUG=false
REPLAY_MAX_FRAMES=1000
